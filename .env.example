# Datenbank (externer PostgreSQL-Server)
DB_HOST=192.168.1.100
DB_PORT=5432
DB_NAME=feuerwehrhub
DB_USER=feuerwehrhub_user
DB_PASSWORD=change-me

# Backend
APP_HOST=0.0.0.0
APP_PORT=3000

# JWT (langer zufälliger String, z.B. mit: openssl rand -hex 64)
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY_HOURS=8

# Feuerwehr
FF_NAME=Freiwillige Feuerwehr Musterstadt

# Sicherheit
# FRONTEND_URL muss exakt der Origin des Frontends entsprechen (kein trailing slash)
FRONTEND_URL=http://localhost:8080
# Max. Fehlversuche beim Login bevor der Account gesperrt wird
LOGIN_MAX_ATTEMPTS=5
# Sperrdauer in Minuten
LOCKOUT_MINUTES=15
