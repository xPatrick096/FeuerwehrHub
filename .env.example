# ═══════════════════════════════════════════════════════════════
#  FeuerwehrHub — Konfiguration
#  Kopiere diese Datei nach .env und passe die Werte an.
# ═══════════════════════════════════════════════════════════════

# ── Betriebsmodus ───────────────────────────────────────────────
#
#  A) Standalone (PostgreSQL inklusive) — empfohlen für Einsteiger:
#     docker compose --profile standalone up -d
#     → DB_HOST und DB_PORT können auf Standard belassen werden.
#
#  B) Externe Datenbank (eigener PostgreSQL-Server):
#     docker compose up -d
#     → DB_HOST auf die IP/den Hostname deines Servers setzen.
#
# ───────────────────────────────────────────────────────────────

# ── Datenbank ───────────────────────────────────────────────────
# Modus A (standalone): Werte so lassen, DB_HOST=postgres
# Modus B (extern):     DB_HOST auf deinen Server zeigen lassen
DB_HOST=postgres
DB_PORT=5432
DB_NAME=feuerwehrhub
DB_USER=feuerwehrhub
DB_PASSWORD=sicheres-passwort-aendern

# ── Backend ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=3000

# JWT — langen zufälligen String generieren:
#   openssl rand -hex 64
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRY_HOURS=8

# ── Feuerwehr ───────────────────────────────────────────────────
FF_NAME=Freiwillige Feuerwehr Musterstadt

# ── Sicherheit ──────────────────────────────────────────────────
# FRONTEND_URL muss exakt der Origin des Frontends entsprechen (kein trailing slash)
FRONTEND_URL=http://localhost:8080
LOGIN_MAX_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Update-Mechanismus ──────────────────────────────────────────────────────
# Docker-Container-Namen für den In-App-Update (müssen mit container_name im Compose übereinstimmen)
CONTAINER_BACKEND=feuerwehrhub-backend
CONTAINER_FRONTEND=feuerwehrhub-frontend
CONTAINER_DB=feuerwehrhub-db
